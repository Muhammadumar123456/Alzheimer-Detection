# =============================================================================
# BACKEND .gitignore
# =============================================================================

# Dependencies
node_modules/

# Environment variables
.env
.env.local
.env.*.local

# Keep the example
!.env.example

# Logs
logs/
*.log
npm-debug.log*

# Uploads (user-uploaded files — keep directory structure via .gitkeep)
uploads/*
!uploads/.gitkeep
!uploads/mri/
uploads/mri/*
!uploads/mri/.gitkeep

# ML Model files (too large for git — use Git LFS or external storage)
*.keras
*.h5

# OS files
.DS_Store
Thumbs.db

# Editor directories
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Coverage & testing
coverage/
.nyc_output/

# Build artifacts
dist/
