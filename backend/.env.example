# =============================================================================
# SERVER
# =============================================================================
NODE_ENV=development
PORT=5000
API_PREFIX=/api

# =============================================================================
# DATABASE (MongoDB Atlas)
# =============================================================================
# Production: MUST be set to your MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname

# =============================================================================
# AUTHENTICATION
# =============================================================================
# Production: MUST be a cryptographically secure random string (>= 64 chars)
JWT_SECRET=your_jwt_secret_must_be_changed_in_production
JWT_EXPIRES_IN=7d

# =============================================================================
# EMAIL (SMTP)
# =============================================================================
# Configure for password reset and contact form emails
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_SECURE=false
SMTP_FROM="AlzDetect System" <noreply@alzdetect.com>
CONTACT_RECIPIENT=admin@alzdetect.com

# =============================================================================
# GOOGLE OAUTH
# =============================================================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
API_BASE_URL=http://localhost:5000

# =============================================================================
# ML MICROSERVICE
# =============================================================================
ML_SERVICE_URL=http://localhost:8000
ML_SERVICE_TIMEOUT=30000

# =============================================================================
# ASYNC & QUEUE & PERFORMANCE (Redis/BullMQ)
# =============================================================================
# Set USE_ASYNC=true for production environments with Redis
USE_ASYNC=false
REDIS_URL=redis://localhost:6379
SAFE_MODE=true
JOB_TIMEOUT=60000
JOB_ATTEMPTS=3
JOB_BACKOFF_DELAY=1000

# =============================================================================
# UPLOADS & STORAGE
# =============================================================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800
