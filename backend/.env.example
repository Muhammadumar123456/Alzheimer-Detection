# =============================================================================
# SERVER
# =============================================================================
NODE_ENV=development
PORT=5000
API_PREFIX=/api

# =============================================================================
# DATABASE
# =============================================================================
# Local:  mongodb://localhost:27017/alzheimer_detection
# Atlas:  mongodb+srv://<username>:<password>@<cluster>.mongodb.net/alzheimer_detection?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/alzheimer_detection?retryWrites=true&w=majority

# =============================================================================
# AUTHENTICATION
# =============================================================================
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# =============================================================================
# AUTHENTICATION (Phase 1)
# =============================================================================
# JWT_SECRET=your-super-secret-key-change-in-production
# JWT_EXPIRES_IN=7d

# =============================================================================
# FILE STORAGE (Phase 2)
# =============================================================================
# UPLOAD_DIR=./uploads
# MAX_FILE_SIZE=10485760

# =============================================================================
# ML SERVICE (Phase 3)
# =============================================================================
# ML_SERVICE_URL=http://localhost:8000
# ML_SERVICE_TIMEOUT=30000

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=debug
LOG_DIR=./logs

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGIN=http://localhost:5173
